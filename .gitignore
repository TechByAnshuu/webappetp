# Ignore environment files
.env
.env.local
.env.*.local

# Node dependencies and logs
node_modules/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Build output
dist/
build/
out/
coverage/

# OS files
.DS_Store
Thumbs.db

# IDEs and editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Logs
*.log

# Docker compose overrides and local docker files
docker-compose.override.yml
.docker/

# MySQL local data (do not ignore Dockerfile or init.sql)
mysql/data/
mysql/*.pid
mysql/*.sock

# Secrets, keys, certificates
*.key
*.pem
*.crt
.secrets

# Temporary files
*.tmp
*.swp
